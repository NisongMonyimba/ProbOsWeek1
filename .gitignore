# Explicitly track all figure outputs
!*.png
!*.PNG

# =============================================================================
# .gitignore for probos-kernel
# =============================================================================
# This file tells Git which files and folders to IGNORE.
# Files listed here will NOT be committed to the repository.
#
# WHY THIS MATTERS:
#   - Build artefacts (*.o, *.so) are machine-specific and must not be shared.
#   - The virtual environment (.venv/) is large and can be recreated from
#     requirements.txt on any machine.
#   - Generated output (*.png, *.csv) should not clutter the history.
# =============================================================================

# ── Python: compiled bytecode ────────────────────────────────────────────────
# Python compiles .py files to .pyc for faster loading.
# These are machine-specific and regenerated automatically.
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Python: virtual environment ──────────────────────────────────────────────
# The virtual environment contains all installed packages.
# It is recreated with: python3 -m venv .venv && pip install -r requirements.txt
.venv/
venv/
env/

# ── Python: packaging artefacts ──────────────────────────────────────────────
*.egg-info/
dist/
*.egg

# ── Python: type checking and linting caches ─────────────────────────────────
.mypy_cache/
.ruff_cache/
.dmypy.json

# ── Python: test and coverage artefacts ──────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── C++: build directory ──────────────────────────────────────────────────────
# Everything generated by cmake and ninja goes in build/.
# Recreate with: mkdir build && cd build && cmake .. -G Ninja && ninja
build/
cmake_install.cmake
CMakeFiles/
CMakeCache.txt
CTestTestfile.cmake
_deps/

# ── C++: compiled object files and libraries ─────────────────────────────────
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# ── IDE: Visual Studio Code ───────────────────────────────────────────────────
# The .vscode/settings.json is machine-specific.
# .vscode/launch.json CAN be committed if your team uses the same debugger.
.vscode/settings.json
.vscode/c_cpp_properties.json

# ── IDE: JetBrains (CLion, PyCharm) ──────────────────────────────────────────
.idea/

# ── IDE: vim/emacs swap files ─────────────────────────────────────────────────
*.swp
*.swo
*~

# ── Operating system artefacts ────────────────────────────────────────────────
.DS_Store        # macOS Finder metadata
Thumbs.db        # Windows thumbnail cache
desktop.ini      # Windows folder settings

# ── Jupyter notebooks: checkpoint folders ─────────────────────────────────────
.ipynb_checkpoints/

# ── Generated output ──────────────────────────────────────────────────────────
# PNG/PDF files generated by examples should not be committed.
# Exception: files under docs/ are intentional documentation assets.
*.pdf
!docs/**/*.png
!docs/**/*.pdf
*.Identifier

# LaTeX build artifacts
manuscript/*.aux
manuscript/*.bbl
manuscript/*.blg
manuscript/*.log
manuscript/*.out
manuscript/*.toc
manuscript/*.fls
manuscript/*.fdb_latexmk
manuscript/*.synctex.gz
